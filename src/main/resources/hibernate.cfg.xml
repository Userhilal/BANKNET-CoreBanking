<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Paramètres de connexion MySQL (Docker) -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/banknet_db?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true</property>
        <property name="hibernate.connection.username">bank_user</property>
        <property name="hibernate.connection.password">bank_pass</property>

        <!-- Dialecte Hibernate pour MySQL -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <!-- Options de connexion -->
        <property name="hibernate.connection.pool_size">10</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.use_sql_comments">true</property>

        <!-- Gestion du schéma : update crée/met à jour les tables automatiquement -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Encodage UTF-8 -->
        <property name="hibernate.connection.characterEncoding">UTF-8</property>
        <property name="hibernate.connection.useUnicode">true</property>

        <!-- Mapping des entités -->
        <mapping class="com.banknet.model.Client"/>
        <mapping class="com.banknet.model.Compte"/>
        <mapping class="com.banknet.model.UserAccount"/>
        <mapping class="com.banknet.model.Transaction"/>
        <mapping class="com.banknet.model.Notification"/>
        <mapping class="com.banknet.model.ObjectifEpargne"/>
        <mapping class="com.banknet.model.PlafondTransaction"/>
        <mapping class="com.banknet.model.Message"/>
        <mapping class="com.banknet.model.ActiviteSuspecte"/>
    </session-factory>
</hibernate-configuration>
