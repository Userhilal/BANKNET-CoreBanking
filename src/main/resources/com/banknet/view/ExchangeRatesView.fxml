<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banknet.controller.ExchangeRatesController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 12px 15px;">
            <Label fx:id="titleLabel" text="Cours de change" styleClass="header-label" style="-fx-font-size: 18px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeButton" text="Fermer" onAction="#handleClose" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-border-color: white; -fx-border-width: 1px; -fx-padding: 6px 12px; -fx-font-size: 12px;"/>
        </HBox>
    </top>
    
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="login-container" style="-fx-padding: 30px;">
            <Label text="💱" style="-fx-font-size: 48px;"/>
            <Label fx:id="subtitleLabel" text="Taux de change en temps réel" styleClass="label-subtitle"/>
            
            <TableView fx:id="ratesTable" style="-fx-max-width: 1200px; -fx-pref-width: 1150px;" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="currencyColumn" text="Devise" minWidth="550" prefWidth="600"/>
                    <TableColumn fx:id="rateColumn" text="Taux (MAD)" minWidth="450" prefWidth="500"/>
                </columns>
            </TableView>
            
            <Label fx:id="disclaimerLabel" text="* Les taux sont actualisés quotidiennement" styleClass="label-subtitle" style="-fx-font-size: 11px;"/>
        </VBox>
    </center>
</BorderPane>

