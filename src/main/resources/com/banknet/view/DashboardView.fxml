<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banknet.controller.DashboardController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
            <Label text="🏦 BANKNET" styleClass="header-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" styleClass="header-label" style="-fx-font-size: 14px;"/>
            <Button fx:id="logoutButton" text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-border-color: white; -fx-border-width: 1px;"/>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f5f5f5;">
            <VBox spacing="20" styleClass="main-container">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                
                <!-- Cartes de solde -->
                <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                    </columnConstraints>
                    
                    <VBox styleClass="card" GridPane.columnIndex="0">
                        <Label fx:id="soldeTotalTitleLabel" text="Solde Total" styleClass="card-title"/>
                        <Label fx:id="soldeTotalLabel" text="0.00 MAD" styleClass="card-value"/>
                    </VBox>
                    
                    <VBox styleClass="card" GridPane.columnIndex="1">
                        <Label fx:id="nombreComptesTitleLabel" text="Nombre de Comptes" styleClass="card-title"/>
                        <Label fx:id="nombreComptesLabel" text="0" styleClass="card-value"/>
                    </VBox>
                    
                    <VBox styleClass="card" GridPane.columnIndex="2">
                        <Label fx:id="soldeMoyenTitleLabel" text="Solde Moyen" styleClass="card-title"/>
                        <Label fx:id="soldeMoyenLabel" text="0.00 MAD" styleClass="card-value"/>
                    </VBox>
                </GridPane>
                
                <!-- Actions -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Button fx:id="activateButton" text="Activer un compte" onAction="#handleActivation" style="-fx-min-width: 150px;"/>
                    <Button fx:id="blockedAccountsButton" text="Comptes bloqués" onAction="#handleBlockedAccounts" style="-fx-min-width: 150px; -fx-background-color: #DC2626; -fx-text-fill: white;"/>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Button fx:id="messagesButton" text="💬 Messages clients" onAction="#handleMessages" style="-fx-min-width: 160px; -fx-background-color: #0056D2; -fx-text-fill: white;"/>
                        <Label fx:id="messagesBadge" text="" style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-padding: 2px 8px; -fx-background-radius: 10px; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false"/>
                    </HBox>
                    <Button fx:id="refreshButton" text="Actualiser" onAction="#handleRefresh" style="-fx-min-width: 150px;"/>
                </HBox>
                
                <!-- Historique des transactions -->
                <VBox spacing="10" styleClass="panel">
                    <Label fx:id="transactionsTitleLabel" text="Historique des Transactions" styleClass="label-title"/>
                    <TableView fx:id="transactionTable" style="-fx-max-height: 400px;">
                        <columns>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
                            <TableColumn fx:id="montantColumn" text="Montant" prefWidth="120"/>
                            <TableColumn fx:id="libelleColumn" text="Libellé" prefWidth="200"/>
                            <TableColumn fx:id="compteSourceColumn" text="Compte Source" prefWidth="150"/>
                            <TableColumn fx:id="compteDestColumn" text="Compte Destination" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
