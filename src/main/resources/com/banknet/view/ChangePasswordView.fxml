<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banknet.controller.ChangePasswordController" style="-fx-background-color: #f5f5f5;">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="panel" style="-fx-min-width: 450px;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <Label fx:id="titleLabel" text="🔑 Changer le mot de passe" styleClass="label-title"/>
            <Label fx:id="subtitleLabel" text="Modifiez votre mot de passe pour sécuriser votre compte" styleClass="label-subtitle" style="-fx-text-alignment: center;" wrapText="true"/>
            
            <VBox spacing="15" style="-fx-min-width: 100%;">
                <Label fx:id="oldPasswordLabel" text="Ancien mot de passe" styleClass="label" style="-fx-font-weight: bold;"/>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <PasswordField fx:id="oldPasswordField" HBox.hgrow="ALWAYS" promptText="Entrez votre mot de passe actuel"/>
                    <TextField fx:id="oldPasswordVisibleField" HBox.hgrow="ALWAYS" promptText="Entrez votre mot de passe actuel" visible="false" managed="false"/>
                    <Button fx:id="toggleOldPasswordButton" text="👁" onAction="#handleToggleOldPassword" styleClass="toggle-password-button" style="-fx-background-color: transparent; -fx-text-fill: #6B7280; -fx-padding: 8px 12px; -fx-min-width: 40px; -fx-cursor: hand;"/>
                </HBox>
                
                <Label fx:id="newPasswordLabel" text="Nouveau mot de passe" styleClass="label" style="-fx-font-weight: bold;"/>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <PasswordField fx:id="newPasswordField" HBox.hgrow="ALWAYS" promptText="Entrez votre nouveau mot de passe"/>
                    <TextField fx:id="newPasswordVisibleField" HBox.hgrow="ALWAYS" promptText="Entrez votre nouveau mot de passe" visible="false" managed="false"/>
                    <Button fx:id="toggleNewPasswordButton" text="👁" onAction="#handleToggleNewPassword" styleClass="toggle-password-button" style="-fx-background-color: transparent; -fx-text-fill: #6B7280; -fx-padding: 8px 12px; -fx-min-width: 40px; -fx-cursor: hand;"/>
                </HBox>
                
                <Label fx:id="confirmPasswordLabel" text="Confirmer le nouveau mot de passe" styleClass="label" style="-fx-font-weight: bold;"/>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <PasswordField fx:id="confirmPasswordField" HBox.hgrow="ALWAYS" promptText="Confirmez votre nouveau mot de passe"/>
                    <TextField fx:id="confirmPasswordVisibleField" HBox.hgrow="ALWAYS" promptText="Confirmez votre nouveau mot de passe" visible="false" managed="false"/>
                    <Button fx:id="toggleConfirmPasswordButton" text="👁" onAction="#handleToggleConfirmPassword" styleClass="toggle-password-button" style="-fx-background-color: transparent; -fx-text-fill: #6B7280; -fx-padding: 8px 12px; -fx-min-width: 40px; -fx-cursor: hand;"/>
                </HBox>
                
                <Label fx:id="errorLabel" styleClass="error-message" visible="false" managed="false" wrapText="true"/>
                <Label fx:id="successLabel" styleClass="success-message" visible="false" managed="false" wrapText="true"/>
                
                <HBox spacing="10">
                    <Button fx:id="changeButton" text="Changer le mot de passe" onAction="#handleChange" style="-fx-min-width: 150px;"/>
                    <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" styleClass="button-secondary" style="-fx-min-width: 150px;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>




