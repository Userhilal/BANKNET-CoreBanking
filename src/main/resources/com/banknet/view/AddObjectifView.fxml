<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banknet.controller.AddObjectifController" style="-fx-background-color: #f5f5f5;">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="panel" style="-fx-min-width: 450px;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <Label fx:id="titleLabel" text="🎯 Nouvel objectif d'épargne" styleClass="label-title"/>
            
            <VBox spacing="15" style="-fx-min-width: 100%;">
                <Label fx:id="libelleLabel" text="Libellé" styleClass="label" style="-fx-font-weight: bold;"/>
                <TextField fx:id="libelleField" promptText="Ex: Vacances, Maison, etc."/>
                
                <Label fx:id="compteLabel" text="Compte" styleClass="label" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="compteCombo" promptText="Sélectionnez un compte"/>
                
                <Label fx:id="montantLabel" text="Montant cible (MAD)" styleClass="label" style="-fx-font-weight: bold;"/>
                <TextField fx:id="montantField" promptText="Ex: 50000"/>
                
                <Label fx:id="dateLabel" text="Date cible" styleClass="label" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="dateCiblePicker"/>
                
                <Label fx:id="errorLabel" styleClass="error-message" visible="false" managed="false" wrapText="true"/>
                
                <HBox spacing="10">
                    <Button fx:id="createButton" text="Créer" onAction="#handleCreate" style="-fx-min-width: 150px;"/>
                    <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" styleClass="button-secondary" style="-fx-min-width: 150px;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>



