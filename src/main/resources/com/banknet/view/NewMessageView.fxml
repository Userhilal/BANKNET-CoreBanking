<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banknet.controller.NewMessageController" style="-fx-background-color: #f5f5f5;">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="panel" style="-fx-min-width: 500px;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <Label fx:id="titleLabel" text="✉️ Nouveau message à la banque" styleClass="label-title"/>
            
            <VBox spacing="15" style="-fx-min-width: 100%;">
                <Label fx:id="sujetLabel" text="Sujet" styleClass="label" style="-fx-font-weight: bold;"/>
                <TextField fx:id="sujetField" promptText="Sujet du message"/>
                
                <Label fx:id="messageLabel" text="Message" styleClass="label" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="contenuArea" promptText="Tapez votre message..." style="-fx-min-height: 200px; -fx-pref-height: 200px;" wrapText="true"/>
                
                <Label fx:id="errorLabel" styleClass="error-message" visible="false" managed="false" wrapText="true"/>
                
                <HBox spacing="10">
                    <Button fx:id="sendButton" text="Envoyer" onAction="#handleSend" style="-fx-min-width: 150px;"/>
                    <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" styleClass="button-secondary" style="-fx-min-width: 150px;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>



